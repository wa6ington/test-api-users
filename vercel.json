{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/site",
      "dest": "/public/index.html"
    },
    {
      "src": "/(auth|users|products|posts|tasks|payments|health|docs)(.*)",
      "dest": "api/index.py"
    }
  ]
}